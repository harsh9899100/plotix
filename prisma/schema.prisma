// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum UserRole {
  BUYER
  AGENT
  BUILDER
  OWNER
  ADMIN
  SUPERADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
  AGRICULTURAL
  MIXED
}

enum ListingFor {
  SALE
  RENT
}

enum PropertyStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  SOLD
  ARCHIVED
}

enum FurnishingStatus {
  FURNISHED
  SEMI_FURNISHED
  UNFURNISHED
}

enum InquiryStatus {
  NEW
  VIEWED
  RESPONDED
  CLOSED
}

enum ViewingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ViewingType {
  IN_PERSON
  VIRTUAL
  VIDEO_CALL
}

enum RequestStatus {
  OPEN
  MATCHED
  CLOSED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  VIEWING_SCHEDULED
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum LeadTemperature {
  HOT
  WARM
  COLD
}

enum TransactionStatus {
  INITIATED
  BOOKING
  IN_PROGRESS
  COMPLETED
  DISPUTED
  REFUNDED
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  VOICE
}

enum NotificationType {
  INQUIRY
  MESSAGE
  VIEWING
  PRICE_DROP
  NEW_LISTING
  PROPERTY_MATCH
  PAYMENT
  SYSTEM
}

enum ProjectStatus {
  PRE_LAUNCH
  LAUNCHED
  SOLD_OUT
  COMPLETED
}

enum ServiceRequestStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum ServiceRequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DocumentStatus {
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
  EXPIRED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactStatus {
  NEW
  READ
  RESPONDED
}

enum CommissionStatus {
  PENDING
  PAID
  CANCELLED
}

// ── User & Auth ─────────────────────────────────────────────────────────────────

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  emailVerified     DateTime?
  phone             String?
  phoneVerified     Boolean    @default(false)
  password          String?
  firstName         String
  lastName          String
  profileImage      String?
  bio               String?
  role              UserRole   @default(BUYER)
  status            UserStatus @default(PENDING_VERIFICATION)
  isOnline          Boolean    @default(false)
  lastSeen          DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  accounts          Account[]
  sessions          Session[]
  agentProfile      AgentProfile?
  builderProfile    BuilderProfile?
  properties        Property[]       @relation("PropertyOwner")
  favorites         Favorite[]
  inquiriesSent     Inquiry[]        @relation("InquiryBuyer")
  inquiriesReceived Inquiry[]        @relation("InquiryAgent")
  propertyRequests  PropertyRequest[]
  savedSearches     SavedSearch[]
  viewingsAsBuyer   Viewing[]        @relation("ViewingBuyer")
  viewingsAsAgent   Viewing[]        @relation("ViewingAgent")
  messagesSent      Message[]        @relation("MessageSender")
  messagesReceived  Message[]        @relation("MessageReceiver")
  reviews           Review[]
  notifications     Notification[]
  blogPosts         BlogPost[]
  testimonials      Testimonial[]
  auditLogs         AuditLog[]
  leadsAssigned     Lead[]           @relation("LeadAgent")
  buyerContacts     BuyerContact[]   @relation("ContactOwner")
  serviceRequests   ServiceRequest[] @relation("ServiceRequester")
  commissions       Commission[]     @relation("CommissionAgent")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ── Agent / Builder Profiles ───────────────────────────────────────────────────

model AgentProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  agencyName        String?
  licenseNumber     String?
  licenseExpiry     DateTime?
  specializations   String[]
  yearsExperience   Int      @default(0)
  commissionRate    Float    @default(3.0)
  verified          Boolean  @default(false)
  rating            Float    @default(0)
  totalSales        Int      @default(0)
  totalListings     Int      @default(0)
  website           String?
  facebookUrl       String?
  instagramUrl      String?
  linkedinUrl       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agent_profiles")
}

model BuilderProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  companyName         String
  registrationNumber  String?
  yearsInBusiness     Int      @default(0)
  numberOfProjects    Int      @default(0)
  logo                String?
  website             String?
  verified            Boolean  @default(false)
  rating              Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects            Project[]

  @@map("builder_profiles")
}

// ── Properties ─────────────────────────────────────────────────────────────────

model Property {
  id               String           @id @default(cuid())
  userId           String
  projectId        String?
  title            String
  slug             String           @unique
  description      String           @db.Text
  type             PropertyType
  listingFor       ListingFor
  status           PropertyStatus   @default(DRAFT)
  furnishing       FurnishingStatus?
  price            Float
  pricePerSqFt     Float?
  area             Float
  bedrooms         Int              @default(0)
  bathrooms        Int              @default(0)
  kitchens         Int              @default(0)
  parking          Int              @default(0)
  floor            Int?
  totalFloors      Int?
  yearBuilt        Int?
  city             String
  state            String
  locality         String?
  address          String
  latitude         Float?
  longitude        Float?
  amenities        String[]
  images           String[]
  virtualTourUrl   String?
  featured         Boolean          @default(false)
  views            Int              @default(0)
  inquiryCount     Int              @default(0)
  approvedAt       DateTime?
  approvedById     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  owner            User             @relation("PropertyOwner", fields: [userId], references: [id])
  project          Project?         @relation(fields: [projectId], references: [id])
  favorites        Favorite[]
  inquiries        Inquiry[]
  viewings         Viewing[]
  reviews          Review[]
  documents        PropertyDocument[]
  comparisons      ComparisonItem[]

  @@map("properties")
}

model PropertyDocument {
  id         String          @id @default(cuid())
  propertyId String
  docType    String
  fileName   String
  fileUrl    String
  uploadedBy String
  status     DocumentStatus  @default(PENDING_VERIFICATION)
  verifiedBy String?
  expiryDate DateTime?
  uploadedAt DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  property   Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_documents")
}

// ── Projects (Builder) ────────────────────────────────────────────────────────

model Project {
  id               String        @id @default(cuid())
  builderId        String
  title            String
  slug             String        @unique
  description      String        @db.Text
  type             PropertyType
  status           ProjectStatus @default(PRE_LAUNCH)
  city             String
  state            String
  address          String
  latitude         Float?
  longitude        Float?
  totalUnits       Int           @default(0)
  unitsAvailable   Int           @default(0)
  startDate        DateTime?
  completionDate   DateTime?
  masterPlanImage  String?
  amenities        String[]
  images           String[]
  brochureUrl      String?
  verified         Boolean       @default(false)
  featured         Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  builder          BuilderProfile @relation(fields: [builderId], references: [id])
  properties       Property[]
  brokerCommissions BrokerCommission[]

  @@map("projects")
}

model BrokerCommission {
  id             String           @id @default(cuid())
  projectId      String?
  builderId      String
  brokerId       String
  commissionRate Float
  status         CommissionStatus @default(PENDING)
  createdAt      DateTime         @default(now())

  project        Project?         @relation(fields: [projectId], references: [id])

  @@map("broker_commissions")
}

// ── Favorites ─────────────────────────────────────────────────────────────────

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  notes      String?
  listName   String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("favorites")
}

// ── Inquiries ──────────────────────────────────────────────────────────────────

model Inquiry {
  id           String        @id @default(cuid())
  propertyId   String
  buyerId      String
  agentId      String?
  name         String
  email        String
  phone        String?
  message      String        @db.Text
  status       InquiryStatus @default(NEW)
  response     String?       @db.Text
  respondedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  property     Property      @relation(fields: [propertyId], references: [id])
  buyer        User          @relation("InquiryBuyer", fields: [buyerId], references: [id])
  agent        User?         @relation("InquiryAgent", fields: [agentId], references: [id])

  @@map("inquiries")
}

// ── Property Requests ─────────────────────────────────────────────────────────

model PropertyRequest {
  id           String        @id @default(cuid())
  userId       String
  title        String
  description  String?       @db.Text
  propertyType PropertyType?
  minPrice     Float?
  maxPrice     Float?
  minArea      Float?
  maxArea      Float?
  bedrooms     Int?
  bathrooms    Int?
  cities       String[]
  amenities    String[]
  status       RequestStatus @default(OPEN)
  createdAt    DateTime      @default(now())
  completedAt  DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("property_requests")
}

// ── Saved Searches ────────────────────────────────────────────────────────────

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  filters   Json
  alertOn   Boolean  @default(true)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_searches")
}

// ── Viewings ──────────────────────────────────────────────────────────────────

model Viewing {
  id            String        @id @default(cuid())
  propertyId    String
  buyerId       String
  agentId       String?
  scheduledAt   DateTime
  duration      Int           @default(60)
  type          ViewingType   @default(IN_PERSON)
  status        ViewingStatus @default(SCHEDULED)
  location      String?
  notes         String?
  buyerFeedback String?
  buyerRating   Int?
  cancelledAt   DateTime?
  cancelReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  property      Property      @relation(fields: [propertyId], references: [id])
  buyer         User          @relation("ViewingBuyer", fields: [buyerId], references: [id])
  agent         User?         @relation("ViewingAgent", fields: [agentId], references: [id])

  @@map("viewings")
}

// ── Comparisons ───────────────────────────────────────────────────────────────

model Comparison {
  id          String           @id @default(cuid())
  userId      String
  name        String?
  createdAt   DateTime         @default(now())

  items       ComparisonItem[]

  @@map("comparisons")
}

model ComparisonItem {
  id           String     @id @default(cuid())
  comparisonId String
  propertyId   String
  addedAt      DateTime   @default(now())

  comparison   Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  property     Property   @relation(fields: [propertyId], references: [id])

  @@map("comparison_items")
}

// ── Leads ─────────────────────────────────────────────────────────────────────

model Lead {
  id           String          @id @default(cuid())
  agentId      String
  name         String
  email        String?
  phone        String?
  source       String?
  status       LeadStatus      @default(NEW)
  temperature  LeadTemperature @default(WARM)
  score        Int             @default(0)
  budget       Float?
  notes        String?         @db.Text
  propertyType PropertyType?
  cities       String[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  agent        User            @relation("LeadAgent", fields: [agentId], references: [id])

  @@map("leads")
}

// ── Buyer Contacts (Agent's CRM) ──────────────────────────────────────────────

model BuyerContact {
  id         String   @id @default(cuid())
  ownerId    String
  name       String
  email      String?
  phone      String?
  budget     Float?
  notes      String?  @db.Text
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner      User     @relation("ContactOwner", fields: [ownerId], references: [id])

  @@map("buyer_contacts")
}

// ── Messages ──────────────────────────────────────────────────────────────────

model Message {
  id          String       @id @default(cuid())
  senderId    String
  receiverId  String
  propertyId  String?
  content     String       @db.Text
  type        MessageType  @default(TEXT)
  attachments String[]
  isRead      Boolean      @default(false)
  readAt      DateTime?
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())

  sender      User         @relation("MessageSender", fields: [senderId], references: [id])
  receiver    User         @relation("MessageReceiver", fields: [receiverId], references: [id])

  @@map("messages")
}

// ── Reviews ───────────────────────────────────────────────────────────────────

model Review {
  id            String   @id @default(cuid())
  propertyId    String
  userId        String
  rating        Int
  comment       String   @db.Text
  agentRating   Int?
  isVerified    Boolean  @default(false)
  isApproved    Boolean  @default(false)
  helpful       Int      @default(0)
  createdAt     DateTime @default(now())

  property      Property @relation(fields: [propertyId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@map("reviews")
}

// ── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  relatedId String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ── Blog ──────────────────────────────────────────────────────────────────────

model BlogPost {
  id            String     @id @default(cuid())
  authorId      String
  title         String
  slug          String     @unique
  content       String     @db.Text
  excerpt       String?
  featuredImage String?
  category      String?
  tags          String[]
  status        BlogStatus @default(DRAFT)
  viewCount     Int        @default(0)
  readTime      Int        @default(5)
  createdAt     DateTime   @default(now())
  publishedAt   DateTime?
  updatedAt     DateTime   @updatedAt

  author        User       @relation(fields: [authorId], references: [id])
  comments      Comment[]

  @@map("blog_posts")
}

model Comment {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  content   String        @db.Text
  status    CommentStatus @default(PENDING)
  createdAt DateTime      @default(now())

  post      BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("comments")
}

// ── Testimonials ──────────────────────────────────────────────────────────────

model Testimonial {
  id          String            @id @default(cuid())
  userId      String
  rating      Int
  message     String            @db.Text
  displayName String?
  role        String?
  image       String?
  status      TestimonialStatus @default(PENDING)
  createdAt   DateTime          @default(now())

  user        User              @relation(fields: [userId], references: [id])

  @@map("testimonials")
}

// ── Contact Messages ──────────────────────────────────────────────────────────

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String        @db.Text
  status    ContactStatus @default(NEW)
  reply     String?       @db.Text
  repliedAt DateTime?
  createdAt DateTime      @default(now())

  @@map("contact_messages")
}

// ── Transactions ──────────────────────────────────────────────────────────────

model Transaction {
  id          String            @id @default(cuid())
  propertyId  String
  buyerId     String
  sellerId    String
  totalAmount Float
  status      TransactionStatus @default(INITIATED)
  notes       String?
  createdAt   DateTime          @default(now())
  completedAt DateTime?

  milestones  TransactionMilestone[]

  @@map("transactions")
}

model TransactionMilestone {
  id            String      @id @default(cuid())
  transactionId String
  type          String
  amount        Float
  dueDate       DateTime
  paidDate      DateTime?
  status        String      @default("pending")
  paymentMethod String?

  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@map("transaction_milestones")
}

// ── Commissions ───────────────────────────────────────────────────────────────

model Commission {
  id           String           @id @default(cuid())
  agentId      String
  propertyId   String?
  transactionId String?
  amount       Float
  rate         Float
  status       CommissionStatus @default(PENDING)
  paidAt       DateTime?
  notes        String?
  createdAt    DateTime         @default(now())

  agent        User             @relation("CommissionAgent", fields: [agentId], references: [id])

  @@map("commissions")
}

// ── Service Requests ──────────────────────────────────────────────────────────

model ServiceRequest {
  id          String                 @id @default(cuid())
  propertyId  String
  userId      String
  title       String
  description String                 @db.Text
  category    String
  status      ServiceRequestStatus   @default(NEW)
  priority    ServiceRequestPriority @default(MEDIUM)
  assignedTo  String?
  completedAt DateTime?
  rating      Int?
  feedback    String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  user        User                   @relation("ServiceRequester", fields: [userId], references: [id])

  @@map("service_requests")
}

// ── Audit Logs ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ── Site Settings ─────────────────────────────────────────────────────────────

model SiteSettings {
  id              String   @id @default(cuid())
  siteTitle       String   @default("PLOTIX Reality")
  siteDescription String?
  logo            String?
  favicon         String?
  maintenanceMode Boolean  @default(false)
  commissionRate  Float    @default(2.0)
  supportEmail    String?
  updatedAt       DateTime @updatedAt

  @@map("site_settings")
}

// ── Announcements ─────────────────────────────────────────────────────────────

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String    @db.Text
  targetRole  UserRole?
  isActive    Boolean   @default(true)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@map("announcements")
}

// ── Feature Flags ─────────────────────────────────────────────────────────────

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  rolloutPct  Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}
